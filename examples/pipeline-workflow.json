{
  "version": "1.0",
  "name": "示例工作流",
  "description": "测试 bash -> python -> node 的数据传递",
  "nodes": [
    {
      "id": "generate-data",
      "type": "bash",
      "name": "生成数据",
      "description": "使用 bash 脚本生成测试数据",
      "inputs": {},
      "output": {
        "type": "object",
        "properties": {
          "message": { "type": "string" },
          "count": { "type": "number" }
        },
        "required": ["message", "count"]
      },
      "config": {
        "script": "./scripts/generate-data.sh",
        "argsPassing": { "type": "stdin" }
      }
    },
    {
      "id": "process-data",
      "type": "python",
      "name": "处理数据",
      "description": "使用 Python 处理数据",
      "inputs": {
        "data": {
          "type": "object",
          "properties": {
            "message": { "type": "string" },
            "count": { "type": "number" }
          }
        }
      },
      "output": {
        "type": "object",
        "properties": {
          "processed": { "type": "boolean" },
          "result": { "type": "string" }
        }
      },
      "config": {
        "script": "./scripts/process-data.py",
        "argsPassing": { "type": "stdin" }
      }
    },
    {
      "id": "finalize",
      "type": "node",
      "name": "最终处理",
      "description": "使用 Node.js 完成最终处理",
      "inputs": {
        "processedData": {
          "type": "object",
          "properties": {
            "processed": { "type": "boolean" },
            "result": { "type": "string" }
          }
        }
      },
      "output": {
        "type": "object",
        "properties": {
          "final": { "type": "string" },
          "timestamp": { "type": "string" }
        }
      },
      "config": {
        "script": "./scripts/finalize.js",
        "argsPassing": { "type": "stdin" }
      }
    }
  ],
  "edges": [
    {
      "id": "edge1",
      "from": { "nodeId": "generate-data" },
      "to": { "nodeId": "process-data", "input": "data" }
    },
    {
      "id": "edge2",
      "from": { "nodeId": "process-data" },
      "to": { "nodeId": "finalize", "input": "processedData" }
    }
  ]
}
