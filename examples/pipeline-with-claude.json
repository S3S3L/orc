{
  "version": "1.0",
  "name": "完整管道工作流",
  "description": "测试 bash -> python -> node -> claude-code 的完整数据传递",
  "nodes": [
    {
      "id": "generate-data",
      "type": "bash",
      "name": "生成数据",
      "description": "使用 bash 脚本生成测试数据",
      "inputs": {},
      "output": {
        "type": "object",
        "properties": {
          "message": { "type": "string" },
          "count": { "type": "number" }
        },
        "required": ["message", "count"]
      },
      "config": {
        "script": "./scripts/generate-data.sh",
        "argsPassing": { "type": "stdin" }
      }
    },
    {
      "id": "process-data",
      "type": "python",
      "name": "处理数据",
      "description": "使用 Python 处理数据",
      "inputs": {
        "data": {
          "type": "object",
          "properties": {
            "message": { "type": "string" },
            "count": { "type": "number" }
          }
        }
      },
      "output": {
        "type": "object",
        "properties": {
          "processed": { "type": "boolean" },
          "result": { "type": "string" },
          "metrics": {
            "type": "object",
            "properties": {
              "processingTime": { "type": "number" },
              "dataSize": { "type": "number" }
            }
          }
        }
      },
      "config": {
        "script": "./scripts/process-data.py",
        "argsPassing": { "type": "stdin" }
      }
    },
    {
      "id": "finalize",
      "type": "node",
      "name": "最终处理",
      "description": "使用 Node.js 完成最终处理",
      "inputs": {
        "processedData": {
          "type": "object",
          "properties": {
            "processed": { "type": "boolean" },
            "result": { "type": "string" },
            "metrics": { "type": "object" }
          }
        }
      },
      "output": {
        "type": "object",
        "properties": {
          "final": { "type": "string" },
          "timestamp": { "type": "string" },
          "analysis": {
            "type": "object",
            "properties": {
              "status": { "type": "string" },
              "notes": { "type": "array", "items": { "type": "string" } }
            }
          }
        }
      },
      "config": {
        "script": "./scripts/finalize.js",
        "argsPassing": { "type": "stdin" }
      }
    },
    {
      "id": "claude-review",
      "type": "claude-code",
      "name": "Claude 代码审查",
      "description": "使用 Claude Code 生成代码审查报告",
      "inputs": {
        "analysis": {
          "type": "object",
          "properties": {
            "final": { "type": "string" },
            "timestamp": { "type": "string" },
            "analysis": { "type": "object" }
          }
        }
      },
      "output": {
        "type": "object",
        "properties": {
          "summary": { "type": "string" },
          "issues": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "severity": { "type": "string" },
                "description": { "type": "string" },
                "suggestion": { "type": "string" }
              }
            }
          },
          "recommendations": { "type": "array", "items": { "type": "string" } }
        }
      },
      "config": {
        "prompt": {
          "markdown": "./prompts/code-review.md",
          "template": false
        },
        "inputMapping": {
          "analysis": { "target": "markdown", "section": "analysis" }
        },
        "execution": {
          "workDir": "claude-review-{{sessionId}}",
          "outputFile": "output.json",
          "audit": {
            "enabled": true,
            "logStdout": true,
            "logStderr": true,
            "saveMessages": true
          }
        },
        "capabilities": {
          "tools": {
            "allowed": ["Read", "Bash", "Write", "Edit"]
          },
          "mcp": {
            "enabled": [],
            "config": ""
          }
        },
        "configTemplates": []
      }
    }
  ],
  "edges": [
    {
      "id": "edge1",
      "from": { "nodeId": "generate-data" },
      "to": { "nodeId": "process-data", "input": "data" }
    },
    {
      "id": "edge2",
      "from": { "nodeId": "process-data" },
      "to": { "nodeId": "finalize", "input": "processedData" }
    },
    {
      "id": "edge3",
      "from": { "nodeId": "finalize" },
      "to": { "nodeId": "claude-review", "input": "analysis" }
    }
  ]
}
