{
  "version": "0.6.0",
  "name": "v0.6.0 功能测试",
  "description": "测试并行执行、错误恢复、条件分支功能",
  "nodes": [
    {
      "id": "start",
      "type": "bash",
      "name": "开始节点",
      "inputs": {},
      "output": {
        "type": "object",
        "properties": {
          "timestamp": { "type": "string" },
          "mode": { "type": "string" }
        }
      },
      "config": {
        "script": "./scripts/start.sh",
        "argsPassing": { "type": "stdin" },
        "retry": {
          "maxAttempts": 2,
          "backoff": "fixed",
          "delayMs": 500
        }
      }
    },
    {
      "id": "parallel-a",
      "type": "bash",
      "name": "并行任务 A",
      "inputs": {
        "config": {
          "type": "object",
          "properties": {
            "timestamp": { "type": "string" },
            "mode": { "type": "string" }
          }
        }
      },
      "output": {
        "type": "object",
        "properties": {
          "task": { "type": "string" },
          "result": { "type": "string" }
        }
      },
      "config": {
        "script": "./scripts/parallel-a.sh",
        "argsPassing": { "type": "stdin" }
      }
    },
    {
      "id": "parallel-b",
      "type": "bash",
      "name": "并行任务 B",
      "inputs": {
        "config": {
          "type": "object",
          "properties": {
            "timestamp": { "type": "string" },
            "mode": { "type": "string" }
          }
        }
      },
      "output": {
        "type": "object",
        "properties": {
          "task": { "type": "string" },
          "result": { "type": "string" }
        }
      },
      "config": {
        "script": "./scripts/parallel-b.sh",
        "argsPassing": { "type": "stdin" }
      }
    },
    {
      "id": "conditional-task",
      "type": "bash",
      "name": "条件任务",
      "inputs": {
        "dataFromA": {
          "type": "object",
          "properties": {
            "task": { "type": "string" },
            "result": { "type": "string" }
          }
        }
      },
      "output": {
        "type": "object",
        "properties": {
          "executed": { "type": "boolean" },
          "message": { "type": "string" }
        }
      },
      "config": {
        "script": "./scripts/conditional-task.sh",
        "argsPassing": { "type": "stdin" }
      }
    },
    {
      "id": "final",
      "type": "bash",
      "name": "最终汇总",
      "inputs": {
        "resultA": {
          "type": "object",
          "properties": {
            "task": { "type": "string" },
            "result": { "type": "string" }
          }
        },
        "resultB": {
          "type": "object",
          "properties": {
            "task": { "type": "string" },
            "result": { "type": "string" }
          }
        }
      },
      "output": {
        "type": "object",
        "properties": {
          "summary": { "type": "string" },
          "totalTasks": { "type": "number" }
        }
      },
      "config": {
        "script": "./scripts/final.sh",
        "argsPassing": { "type": "stdin" }
      }
    }
  ],
  "edges": [
    {
      "id": "edge-start-to-a",
      "from": { "nodeId": "start" },
      "to": { "nodeId": "parallel-a", "input": "config" }
    },
    {
      "id": "edge-start-to-b",
      "from": { "nodeId": "start" },
      "to": { "nodeId": "parallel-b", "input": "config" }
    },
    {
      "id": "edge-a-to-conditional",
      "from": { "nodeId": "parallel-a" },
      "to": { "nodeId": "conditional-task", "input": "dataFromA" },
      "condition": {
        "expression": "outputs['parallel-a']?.result === 'completed'",
        "onSkip": "skip-edge"
      }
    },
    {
      "id": "edge-a-to-final",
      "from": { "nodeId": "parallel-a" },
      "to": { "nodeId": "final", "input": "resultA" }
    },
    {
      "id": "edge-b-to-final",
      "from": { "nodeId": "parallel-b" },
      "to": { "nodeId": "final", "input": "resultB" }
    }
  ]
}
