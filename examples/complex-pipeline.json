{
  "version": "1.0",
  "name": "复杂工作流测试",
  "description": "验证一对多输出、多对一输入和循环子图功能",
  "schemaBaseDir": ["./schemas/complex"],
  "nodes": [
    {
      "id": "init",
      "type": "bash",
      "name": "初始化数据",
      "description": "生成基础数据，输出会被传递给两个下游节点",
      "config": {
        "script": "./scripts/complex/init-data.sh",
        "argsPassing": { "type": "stdin" }
      }
    },
    {
      "id": "fetch-user",
      "type": "bash",
      "name": "获取用户数据",
      "description": "使用 init 的数据获取用户信息",
      "config": {
        "script": "./scripts/complex/fetch-user.sh",
        "argsPassing": { "type": "stdin" }
      }
    },
    {
      "id": "fetch-config",
      "type": "bash",
      "name": "获取配置数据",
      "description": "使用 init 的数据获取配置信息",
      "config": {
        "script": "./scripts/complex/fetch-config.sh",
        "argsPassing": { "type": "stdin" }
      }
    },
    {
      "id": "merge-data",
      "type": "python",
      "name": "合并数据",
      "description": "接收两个上游节点的输出并合并",
      "config": {
        "script": "./scripts/complex/merge-data.py",
        "argsPassing": { "type": "stdin" }
      }
    },
    {
      "id": "data-validation-loop",
      "type": "loop",
      "name": "数据校验循环",
      "description": "循环校验合并后的数据，失败时修复并最多重试3次",
      "config": {
        "subGraph": {
          "nodes": [
            {
              "id": "validate",
              "type": "bash",
              "name": "校验数据",
              "config": {
                "script": "./scripts/complex/validate-data.sh",
                "argsPassing": { "type": "stdin" }
              }
            },
            {
              "id": "fix",
              "type": "bash",
              "name": "修复数据",
              "config": {
                "script": "./scripts/complex/fix-data.sh",
                "argsPassing": { "type": "stdin" }
              }
            }
          ],
          "edges": [
            {
              "id": "edge-validate-to-fix",
              "from": { "nodeId": "validate" },
              "to": { "nodeId": "fix", "input": "data" }
            }
          ]
        },
        "maxAttempts": 3,
        "validator": "outputs['validate']?.valid === true"
      }
    },
    {
      "id": "report",
      "type": "node",
      "name": "生成报告",
      "description": "使用合并后的数据生成最终报告",
      "config": {
        "script": "./scripts/complex/generate-report.js",
        "argsPassing": { "type": "stdin" }
      }
    },
    {
      "id": "claude-analysis",
      "type": "claude-code",
      "name": "AI 数据分析",
      "description": "使用 Claude Code 对合并数据进行智能分析并生成报告",
      "config": {
        "prompt": {
          "markdown": "./prompts/complex/analysis-report.md",
          "template": true
        },
        "execution": {
          "workDir": "{{nodeId}}",
          "outputFile": "analysis-output.json",
          "audit": {
            "enabled": true,
            "logStdout": true,
            "logStderr": true,
            "saveMessages": true
          }
        },
        "capabilities": {
          "tools": {
            "allowed": ["Read", "Bash"]
          }
        }
      }
    }
  ],
  "edges": [
    {
      "id": "edge-init-to-user",
      "from": { "nodeId": "init" },
      "to": { "nodeId": "fetch-user", "input": "config" }
    },
    {
      "id": "edge-init-to-config",
      "from": { "nodeId": "init" },
      "to": { "nodeId": "fetch-config", "input": "config" }
    },
    {
      "id": "edge-user-to-merge",
      "from": { "nodeId": "fetch-user" },
      "to": { "nodeId": "merge-data", "input": "userData" }
    },
    {
      "id": "edge-config-to-merge",
      "from": { "nodeId": "fetch-config" },
      "to": { "nodeId": "merge-data", "input": "appConfig" }
    },
    {
      "id": "edge-merge-to-loop",
      "from": { "nodeId": "merge-data" },
      "to": { "nodeId": "data-validation-loop", "input": "data" }
    },
    {
      "id": "edge-loop-to-report",
      "from": { "nodeId": "data-validation-loop" },
      "to": { "nodeId": "report", "input": "data" }
    },
    {
      "id": "edge-loop-to-claude",
      "from": { "nodeId": "data-validation-loop" },
      "to": { "nodeId": "claude-analysis", "input": "mergedData" }
    }
  ]
}
